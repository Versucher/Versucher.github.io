---
const navItems = [
  { name: '0x01 // Home', href: '/' },
  { name: '0x02 // Blog', href: '/blog' },
  { name: '0x03 // Tools', href: '/tools' },
  { name: '0x04 // AI applications', href: '/ai' },
];
---

<div class="p-6 h-full flex flex-col justify-between space-y-8">
  <div>
    <div class="mb-8">
      <h1 class="text-xl font-bold text-emerald-400 tracking-wider font-mono">
        &gt;_ Mystery_HUB
      </h1>
      <p class="text-xs text-zinc-500 mt-1">Frontend Testing</p>
    </div>

    <nav class="space-y-2">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="block px-3 py-2 rounded text-zinc-400 hover:text-emerald-400 hover:bg-zinc-800/50 transition-all duration-200 border-l-2 border-transparent hover:border-emerald-500 text-sm"
        >
          {item.name}
        </a>
      ))}
    </nav>
  </div>

  <div class="pt-4 border-t border-zinc-800 text-xxs text-zinc-600 space-y-1">
    <div>SYS_STATUS: <span class="text-emerald-500">ONLINE</span></div>
    <div>TOTAL_PV: <span id="pv-count" class="text-zinc-400">LOADING...</span></div>
  </div>
</div>
