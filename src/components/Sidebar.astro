---
const navItems = [
  { name: '0x01 // Home', href: '/' },
  { name: '0x02 // Blog', href: '/blog' },
  { name: '0x03 // Tools', href: '/tools' },
  { name: '0x04 // AI applications', href: '/ai' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div class="flex h-full flex-col justify-between gap-8 p-5 sm:p-6">
  <div>
    <div class="mb-8">
      <h1 class="text-xl font-bold text-emerald-400 tracking-wider font-mono">
        &gt;_ Mystery_HUB
      </h1>
      <p class="mt-1 text-xs text-zinc-500">Digital workspace</p>
    </div>

    <nav class="space-y-2" aria-label="Primary">
      {navItems.map((item) => {
        // 子页面沿用父级导航的高亮状态。
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = itemPath === '/' ? currentPath === '/' : currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);

        return (
          <a
            href={item.href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'block rounded border-l-2 px-3 py-2 text-sm transition-all duration-200',
              isActive
                ? 'border-emerald-400 bg-emerald-500/10 text-emerald-300'
                : 'border-transparent text-zinc-400 hover:border-emerald-500 hover:bg-zinc-800/50 hover:text-emerald-400',
            ]}
          >
            {item.name}
          </a>
        );
      })}
    </nav>
  </div>

  <div class="space-y-1 border-t border-zinc-800 pt-4 text-[10px] uppercase tracking-wide text-zinc-600">
    <div>SYS_STATUS: <span class="text-emerald-500">ONLINE</span></div>
    <div>BUILD: <span class="text-zinc-400">ASTRO_STATIC</span></div>
  </div>
</div>
