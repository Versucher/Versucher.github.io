---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const {
  title,
  description = 'A note from Mystery_HUB.',
  date,
  tags = [],
} = frontmatter;

const formattedDate = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
}).format(new Date(date));
---

<BaseLayout title={`${title} // Blog`} description={description}>
  <article class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/35 shadow-2xl shadow-black/25">
    <header class="border-b border-zinc-800 bg-zinc-950/70 p-6 md:p-8">
      <a href="/blog" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to articles</a>
      <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-zinc-100 md:text-4xl">{title}</h1>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-zinc-400">{description}</p>
      <div class="mt-5 flex flex-wrap items-center gap-3 text-xs text-zinc-500">
        <time datetime={date}>{formattedDate}</time>
        {tags.map((tag) => (
          <span class="rounded border border-zinc-800 px-2 py-1 uppercase tracking-wide text-zinc-500">{tag}</span>
        ))}
      </div>
    </header>

    <div class="markdown-body p-6 md:p-8">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Markdown 正文样式集中放在这里，方便后续文章直接继承。 */
  .markdown-body {
    color: #d4d4d8;
    font-size: 0.95rem;
    line-height: 1.85;
  }

  .markdown-body h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: #f4f4f5;
    font-size: 1.35rem;
    font-weight: 800;
  }

  .markdown-body h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: #e4e4e7;
    font-size: 1.05rem;
    font-weight: 700;
  }

  .markdown-body p,
  .markdown-body ul,
  .markdown-body ol {
    margin-top: 1rem;
  }

  .markdown-body ul,
  .markdown-body ol {
    padding-left: 1.25rem;
  }

  .markdown-body li {
    margin-top: 0.4rem;
  }

  .markdown-body a {
    color: #34d399;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .markdown-body code {
    border: 1px solid #3f3f46;
    border-radius: 0.25rem;
    background: #09090b;
    padding: 0.08rem 0.3rem;
    color: #a7f3d0;
    font-size: 0.86em;
  }

  .markdown-body pre {
    margin-top: 1rem;
    overflow-x: auto;
    border: 1px solid #27272a;
    border-radius: 0.5rem;
    background: #09090b;
    padding: 1rem;
  }

  .markdown-body pre code {
    border: 0;
    background: transparent;
    padding: 0;
    color: #d4d4d8;
  }
</style>
