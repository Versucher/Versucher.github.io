---
import BaseLayout from '../layouts/BaseLayout.astro';

const experiments = [
  ['Prompt lab', 'Compare prompts and preserve versions that produce stable output.'],
  ['Agent tasks', 'Track small coding-agent workflows from request to verification.'],
  ['Model notes', 'Keep practical observations about latency, quality, and fit.'],
];
---

<BaseLayout title="0x04 // AI Apps">
  <header class="border-b border-zinc-800 pb-4">
    <div class="text-xs text-emerald-400">// AI_APPLICATIONS</div>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">&gt;_ AI Terminal</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      A workspace for practical AI experiments, prompt notes, and interface ideas.
    </p>
  </header>

  <div class="rounded border border-amber-900/50 bg-amber-950/10 p-4 text-xs leading-6 text-amber-300">
    API credentials should stay outside the static site. Future demos can use local-only inputs
    or documented mock responses.
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    {experiments.map(([title, body]) => (
      <section class="rounded border border-zinc-800 bg-zinc-900/25 p-5">
        <h3 class="text-sm font-bold text-zinc-200">{title}</h3>
        <p class="mt-3 text-xs leading-5 text-zinc-500">{body}</p>
      </section>
    ))}
  </div>
</BaseLayout>
