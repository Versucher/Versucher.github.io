---
import BaseLayout from '../layouts/BaseLayout.astro';
// 1. 引入 getCollection API
import { getCollection } from 'astro:content';

// 2. 获取所有的博客文章
const allPosts = await getCollection('blog');

// 3. 映射并排序数据 (将 frontmatter 改为 data，手动拼接 url)
const posts = allPosts
.map((post) => ({
title: post.data.title,
description: post.data.description,
date: post.data.date,
tags: post.data.tags ?? [],
url: `/blog/${post.slug}`, // ✅ 修正：加上結尾反引號 使用 slug 生成动态路由的 URL
}))
.sort((a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf());

const formatDate = (date) =>
new Intl.DateTimeFormat('en', {
year: 'numeric',
month: 'short',
day: '2-digit',
}).format(new Date(date));
---


<BaseLayout title="0x02 // Blog">
  <header class="border-b border-zinc-800 pb-4">
    <div class="text-xs text-emerald-400">// WRITING_BUFFER</div>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">&gt;_ Articles</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Notes, build logs, and reusable workflow records generated from Markdown files.
    </p>
  </header>

  <div class="grid gap-4">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="rounded border border-zinc-800 bg-zinc-900/25 p-5 transition hover:border-emerald-500/50 hover:bg-zinc-900/45">
          <a href={post.url} class="block">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <h3 class="text-base font-bold text-zinc-100">{post.title}</h3>
              <time datetime={post.date} class="text-xs text-zinc-500">{formatDate(post.date)}</time>
            </div>
            <p class="mt-3 text-sm leading-6 text-zinc-400">{post.description}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="rounded border border-zinc-800 px-2 py-1 text-[10px] uppercase tracking-wide text-zinc-500">{tag}</span>
              ))}
            </div>
          </a>
        </article>
      ))
    ) : (
      <div class="rounded border border-zinc-800 bg-zinc-900/25 p-5 text-sm text-zinc-500">
        No articles yet. Add a Markdown file under <code>src/content/blog/</code> to publish one.
      </div>
    )}
  </div>
</BaseLayout>