---
import BaseLayout from '../../layouts/BaseLayout.astro';


const tools = [
  { title: 'AI Chat', desc: 'for Personal test。', url: '/meineai/chat' },
  { title: 'Prompt lab', desc: 'Compare prompts and preserve versions that produce stable output.', url: null },
  { title: 'Agent tasks', desc: 'Track small coding-agent workflows from request to verification.', url: null },
];
---

<BaseLayout title="Meine AI // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/ai" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to AI Terminal</a>
    <div class="mt-2 text-xs text-purple-400">// PERSÖNLICHE_KI</div>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">&gt;_ Meine AI</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Personal AI tools with pre-configured credentials. API keys are stored in Cloudflare Worker, never exposed to the browser.
    </p>
  </header>

  <div class="rounded border border-purple-900/50 bg-purple-950/10 p-4 text-xs leading-6 text-purple-300">
    All requests are proxied through Cloudflare Worker. No API keys are stored in the frontend.
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    {tools.map((item) => {
      const isReady = !!item.url;
      const Tag = isReady ? 'a' : 'section';
      return (
        <Tag
          href={item.url || undefined}
          class={`rounded border border-zinc-800 bg-zinc-900/25 p-5 ${
            isReady ? 'transition hover:border-purple-500/50 hover:bg-zinc-900/45' : ''
          }`}
        >
          <h3 class="text-sm font-bold text-zinc-200">{item.title}</h3>
          <p class="mt-3 text-xs leading-5 text-zinc-500">{item.desc}</p>
          {isReady && (
            <div class="mt-4 text-[10px] uppercase tracking-wide text-purple-400">open tool →</div>
          )}
        </Tag>
      );
    })}
  </div>
</BaseLayout>