---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="0x03 // Tools">
  <h2 class="text-2xl font-bold text-emerald-400 border-b border-zinc-800 pb-2">&gt;_ tools</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
    <div class="border border-zinc-800 p-4 rounded bg-zinc-900/20">
      <div class="text-zinc-200 font-bold text-sm">Fro JSON</div>
      <p class="text-xs text-zinc-500 mt-1">Local caching processing, never uploaded to the server.</p>
    </div>
    <div class="border border-zinc-800 p-4 rounded bg-zinc-900/20">
      <div class="text-zinc-200 font-bold text-sm">Regex test</div>
      <p class="text-xs text-zinc-500 mt-1">Front-end real-time matching, instantaneous feedback.</p>
    </div>
  </div>
</BaseLayout>