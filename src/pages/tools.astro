---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = [
  {
    title: 'JSON formatter',
    description: 'Format and inspect JSON locally in the browser.',
    url: '/tools/json-formatter',
  },
  {
    title: 'Regex tester',
    description: 'Test patterns with immediate front-end feedback.',
    url: '/tools/regex-tester',
  },
  {
    title: 'Snippet vault',
    description: 'Keep reusable commands and code fragments close to the workspace.',
    url: '/tools/snippet-vault',
  },
  {
    title: 'Link checker',
    description: 'Track important site links before shipping changes.',
    url: '/tools/link-checker',
  },
  {
    title: 'Crypto toolkit',
    description: 'Classical ciphers and encoding utilities.',
    url: '/tools/crypto',
  },
  {
    title: 'Color Playground',
    description: 'HEX, RGB, HSL, contrast checker, and palette generator.',
    url: '/tools/color-playground',
  },
  {
    title: 'Encoder / Decoder',
    description: 'Base64, URL, HTML entities, and Unicode escape.',
    url: '/tools/encoder-decoder',
  },
  {
    title: 'Timestamp Converter',
    description: 'Unix timestamps to human dates, with relative time.',
    url: '/tools/timestamp-converter',
  },
  {
    title: 'QR Code Generator',
    description: 'Create custom QR codes for any text or URL.',
    url: '/tools/qr-code',
  },
  {
    title: 'Markdown Preview',
    description: 'Live Markdown to HTML renderer.',
    url: '/tools/markdown-preview',
  },
  {
    title: 'Diff Checker',
    description: 'Line-by-line text comparison with highlighted changes.',
    url: '/tools/diff-checker',
  },
  {
    title: 'Image Compressor',
    description: 'Compress images locally, adjust quality and size.',
    url: '/tools/image-compressor',
  },
];

---

<BaseLayout title="0x03 // Tools">
  <!-- header 區塊與前面相同，省略 -->

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
    {tools.map((tool) => {
      const isReady = !!tool.url;
      const Tag = isReady ? 'a' : 'div';   // 如果有連結就用 <a>，否則用 <div>
      const href = tool.url || undefined;
      
      return (
        <Tag
          href={href}
          class={`rounded border border-zinc-800 bg-zinc-900/25 p-5 ${
            isReady ? 'transition hover:border-emerald-500/50 hover:bg-zinc-900/45' : ''
          }`}
        >
          <div class="text-sm font-bold text-zinc-200">{tool.title}</div>
          <p class="mt-2 text-xs leading-5 text-zinc-500">{tool.description}</p>
          <div class={`mt-4 text-[10px] uppercase tracking-wide ${isReady ? 'text-emerald-400' : 'text-zinc-500'}`}>
            {isReady ? 'open tool →' : 'coming soon'}
          </div>
        </Tag>
      );
    })}
  </div>
</BaseLayout>