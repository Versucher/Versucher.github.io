// ===== 輔助函式：取得包含國旗的隊伍顯示名稱 =====
function getTeamDisplay(name: string) {
  if (!name) return '—';
  const code = flagMap[name];
  if (!code) return name;
  const flag = countryCodeToFlag(code);
  return flag + ' ' + name;
}

