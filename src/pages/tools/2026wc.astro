<BaseLayout title="2026 World Cup // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">2026 世界盃對陣表</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      FIFA World Cup 2026™ 完整賽程與小組分佈。<br />
      <span class="text-xs text-zinc-600">* 賽程資料僅供參考，實際以 FIFA 官方為準。</span>
    </p>
  </header>

  <!-- 小組賽分組 -->
  <section class="mt-8">
    <h3 class="text-lg font-bold text-zinc-200 mb-4">小組賽分組</h3>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
      {groups.map((group) => (
        <div class="rounded-lg border border-zinc-800 bg-zinc-900/40 p-4 hover:border-emerald-500/50 transition">
          <div class="text-sm font-bold text-emerald-400 mb-2">{group.name}</div>
          <ul class="space-y-1">
            {group.teams.map((team) => (
              <li class="text-xs text-zinc-400">{getTeamDisplay(team)}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- 賽程表 -->
  <section class="mt-12">
    <h3 class="text-lg font-bold text-zinc-200 mb-4">全部賽程</h3>
    <div class="overflow-x-auto rounded-xl border border-zinc-800 bg-zinc-950/50">
      <table class="w-full text-xs sm:text-sm">
        <thead class="border-b border-zinc-800 bg-zinc-900/80 text-left">
          <tr>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap">日期</th>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap">北京時間</th>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap">階段</th>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap text-right">主隊</th>
            <th class="py-3 px-2 text-center font-medium text-zinc-600">VS</th>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap">客隊</th>
            <th class="py-3 px-4 font-medium text-zinc-400 whitespace-nowrap">狀態</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          {matches.map((m) => {
            let stageColor = '';
            if (m.stage === '小組賽') stageColor = 'bg-blue-900/40 text-blue-300 border-blue-700';
            else if (m.stage === '32強賽') stageColor = 'bg-purple-900/40 text-purple-300 border-purple-700';
            else if (m.stage === '16強賽') stageColor = 'bg-indigo-900/40 text-indigo-300 border-indigo-700';
            else if (m.stage === '8強賽') stageColor = 'bg-orange-900/40 text-orange-300 border-orange-700';
            else if (m.stage === '半決賽') stageColor = 'bg-yellow-900/40 text-yellow-300 border-yellow-700';
            else if (m.stage === '季軍賽' || m.stage === '決賽') stageColor = 'bg-emerald-900/40 text-emerald-300 border-emerald-700';

            return (
              <tr class="hover:bg-zinc-900/50 transition">
                <td class="py-3 px-4 text-zinc-400 font-mono whitespace-nowrap">{m.date}</td>
                <td class="py-3 px-4 text-zinc-300 font-mono">{m.time}</td>
                <td class="py-3 px-4">
                  <span class={`inline-block rounded-full border px-2 py-0.5 text-[10px] font-medium uppercase ${stageColor}`}>
                    {m.stage}
                  </span>
                </td>
                <td class="py-3 px-4 text-right text-zinc-300 whitespace-nowrap">{getTeamDisplay(m.home)}</td>
                <td class="py-3 px-2 text-center text-zinc-600">VS</td>
                <td class="py-3 px-4 text-zinc-300 whitespace-nowrap">{getTeamDisplay(m.away)}</td>
                <td class="py-3 px-4">
                  <span class="text-[10px] text-zinc-600 font-medium">未開始</span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
    <p class="mt-2 text-xs text-zinc-600">* 淘汰賽階段對陣隊伍待小組賽結束後產生。</p>
  </section>
</BaseLayout>