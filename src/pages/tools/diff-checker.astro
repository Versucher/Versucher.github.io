---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Diff Checker // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">Diff Checker</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Compare two text blocks line by line — find differences instantly.
    </p>
  </header>

  <div id="diff-app" class="mt-6 space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-xs text-zinc-400 mb-1">Original Text</label>
        <textarea id="original-text" rows="10" placeholder="Enter original text..." class="w-full rounded border border-zinc-800 bg-zinc-900/50 px-3 py-2 text-sm font-mono text-zinc-200 outline-none focus:border-emerald-500 resize-y"></textarea>
      </div>
      <div>
        <label class="block text-xs text-zinc-400 mb-1">Modified Text</label>
        <textarea id="modified-text" rows="10" placeholder="Enter modified text..." class="w-full rounded border border-zinc-800 bg-zinc-900/50 px-3 py-2 text-sm font-mono text-zinc-200 outline-none focus:border-emerald-500 resize-y"></textarea>
      </div>
    </div>
    <div class="flex gap-3">
      <button id="compare-btn" class="rounded bg-emerald-600 px-4 py-2 text-xs font-bold text-white hover:bg-emerald-500">Compare</button>
      <button id="clear-btn" class="rounded border border-zinc-800 px-4 py-2 text-xs text-zinc-400 hover:text-zinc-200">Clear</button>
    </div>
    <div id="diff-output" class="rounded border border-zinc-800 bg-zinc-950 p-4 font-mono text-sm whitespace-pre-wrap break-all text-zinc-300 min-h-[200px]"></div>
  </div>
</BaseLayout>

<script type="module">
  import { diffLines } from 'https://cdn.jsdelivr.net/npm/diff@5.1.0/+esm';

  const originalText = document.getElementById('original-text');
  const modifiedText = document.getElementById('modified-text');
  const compareBtn = document.getElementById('compare-btn');
  const clearBtn = document.getElementById('clear-btn');
  const outputDiv = document.getElementById('diff-output');

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;');
  }

  function computeDiff() {
    const oldStr = originalText.value;
    const newStr = modifiedText.value;
    const changes = diffLines(oldStr, newStr, { ignoreWhitespace: false });

    let html = '';
    for (const part of changes) {
      const lines = part.value.split('\n');
      // 移除末尾空行（因为 split 会产生）
      if (lines[lines.length - 1] === '') lines.pop();

      for (const line of lines) {
        if (part.added) {
          html += `<div class="bg-emerald-900/30 border-l-4 border-emerald-500 pl-2 py-0.5"><span class="text-emerald-400">+ </span>${escapeHtml(line)}</div>`;
        } else if (part.removed) {
          html += `<div class="bg-red-900/30 border-l-4 border-red-500 pl-2 py-0.5"><span class="text-red-400">- </span>${escapeHtml(line)}</div>`;
        } else {
          html += `<div class="pl-2 py-0.5"><span class="text-zinc-600">  </span>${escapeHtml(line)}</div>`;
        }
      }
    }
    outputDiv.innerHTML = html || 'No differences found.';
  }

  compareBtn.addEventListener('click', computeDiff);
  clearBtn.addEventListener('click', () => {
    originalText.value = '';
    modifiedText.value = '';
    outputDiv.innerHTML = '';
  });
</script>