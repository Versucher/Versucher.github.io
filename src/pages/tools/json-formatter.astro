---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonFormatter from '../../components/JsonFormatter.astro';
---

<BaseLayout title="JSON Formatter // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">JSON formatter</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Format and inspect JSON locally in the browser.
    </p>
  </header>

  <div class="mt-6">
    <JsonFormatter />
  </div>
</BaseLayout>