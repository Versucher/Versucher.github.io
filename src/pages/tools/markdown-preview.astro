---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Markdown Preview // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">Markdown Preview</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Write Markdown and see the rendered HTML — live, with syntax highlighting.
    </p>
  </header>

  <div id="markdown-app" class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <label class="block text-xs text-zinc-400 mb-1">Markdown</label>
      <textarea id="md-input" rows="16" placeholder="Type your Markdown here..." class="w-full h-full min-h-[400px] rounded border border-zinc-800 bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 outline-none focus:border-emerald-500 resize-y font-mono"></textarea>
    </div>
    <div>
      <label class="block text-xs text-zinc-400 mb-1">Preview</label>
      <div id="md-preview" class="rounded border border-zinc-800 bg-zinc-950 p-4 prose prose-invert prose-sm max-w-none text-zinc-300 overflow-y-auto min-h-[400px]"></div>
    </div>
  </div>
</BaseLayout>

<!-- 引入 highlight.js 暗色主題 -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/styles/atom-one-dark.css" />

<script type="module">
  import { marked } from 'https://cdn.jsdelivr.net/npm/marked@9.1.6/+esm';
  import hljs from 'https://cdn.jsdelivr.net/npm/highlight.js@11.9.0/+esm';

  const input = document.getElementById('md-input');
  const preview = document.getElementById('md-preview');

  // 設定 marked 基本選項（不再使用 highlight 回呼）
  marked.setOptions({
    breaks: true,
    gfm: true,
  });

  // 渲染函式：先生成 HTML，再對所有程式碼區塊手動高亮
  function render() {
    preview.innerHTML = marked.parse(input.value);

    // 選取所有 <pre><code> 元素，呼叫 highlight.js 高亮
    preview.querySelectorAll('pre code').forEach((block) => {
      hljs.highlightElement(block);
    });
  }

  // 防抖處理
  let timer;
  input.addEventListener('input', () => {
    clearTimeout(timer);
    timer = setTimeout(render, 200);
  });

  // 初始範例文字
  const exampleText = [
    "# Hello Markdown",
    "",
    "**Bold text** and *italic*.",
    "",
    "- list item 1",
    "- list item 2",
    "",
    "```javascript",
    "// 這是一個 JavaScript 範例",
    "function greet(name) {",
    "  return `Hello, ${name}!`;",
    "}",
    "console.log(greet('World'));",
    "```",
    "",
    "> Blockquote",
    "",
    "[Link](https://example.com)"
  ].join('\n');

  input.value = exampleText;
  render();
</script>