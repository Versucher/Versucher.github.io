---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Regex Tester // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">Regex tester</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Test patterns with immediate front-end feedback.
    </p>
  </header>

  <div id="regex-app" class="mt-6 space-y-6">
    <!-- 輸入區域 -->
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
      <!-- 正則表達式輸入 -->
      <div>
        <label for="regex-input" class="mb-1.5 block text-xs font-medium text-zinc-400">Regular Expression</label>
        <div class="relative">
          <span class="absolute left-3 top-2.5 select-none text-sm text-zinc-600">/</span>
          <input
            type="text"
            id="regex-input"
            placeholder="pattern"
            class="w-full rounded border border-zinc-800 bg-zinc-900/50 py-2 pl-8 pr-12 text-sm text-zinc-200 placeholder-zinc-600 outline-none focus:border-emerald-500"
          />
          <span class="absolute right-3 top-2.5 select-none text-sm text-zinc-600">/</span>
        </div>
        <!-- 正則標誌 -->
        <div class="mt-2 flex flex-wrap gap-2">
          <label class="flex items-center gap-1.5 text-xs text-zinc-400">
            <input type="checkbox" id="flag-global" checked class="accent-emerald-500" />
            global (g)
          </label>
          <label class="flex items-center gap-1.5 text-xs text-zinc-400">
            <input type="checkbox" id="flag-ignorecase" class="accent-emerald-500" />
            ignoreCase (i)
          </label>
          <label class="flex items-center gap-1.5 text-xs text-zinc-400">
            <input type="checkbox" id="flag-multiline" class="accent-emerald-500" />
            multiline (m)
          </label>
          <label class="flex items-center gap-1.5 text-xs text-zinc-400">
            <input type="checkbox" id="flag-dotall" class="accent-emerald-500" />
            dotAll (s)
          </label>
          <label class="flex items-center gap-1.5 text-xs text-zinc-400">
            <input type="checkbox" id="flag-unicode" class="accent-emerald-500" />
            unicode (u)
          </label>
        </div>
      </div>

      <!-- 測試文字輸入 -->
      <div>
        <label for="test-input" class="mb-1.5 block text-xs font-medium text-zinc-400">Test String</label>
        <textarea
          id="test-input"
          rows="5"
          placeholder="Enter test string..."
          class="w-full rounded border border-zinc-800 bg-zinc-900/50 py-2 px-3 text-sm text-zinc-200 placeholder-zinc-600 outline-none focus:border-emerald-500 resize-y"
        ></textarea>
        <button id="clear-btn" class="mt-2 text-xs text-zinc-500 hover:text-zinc-300">Clear</button>
      </div>
    </div>

    <!-- 結果區域 -->
    <div id="results-area" class="space-y-4">
      <!-- 匹配摘要 -->
      <div id="match-summary" class="hidden rounded border border-zinc-800 bg-zinc-900/25 p-4 text-sm">
        <span id="match-count" class="text-emerald-400 font-bold"></span>
      </div>

      <!-- 錯誤訊息 -->
      <div id="error-message" class="hidden rounded border border-red-800 bg-red-900/20 p-4 text-sm text-red-300"></div>

      <!-- 匹配高亮顯示 -->
      <div class="rounded border border-zinc-800 bg-zinc-950 p-4">
        <pre id="highlight-output" class="whitespace-pre-wrap text-sm font-mono text-zinc-300 leading-relaxed"></pre>
      </div>

      <!-- 詳細匹配結果與捕獲分組 -->
      <div id="match-details" class="space-y-3"></div>
    </div>
  </div>
</BaseLayout>

<script>
  // ---------- 元素引用 ----------
  const regexInput = document.getElementById('regex-input');
  const testInput = document.getElementById('test-input');
  const flagGlobal = document.getElementById('flag-global');
  const flagIgnoreCase = document.getElementById('flag-ignorecase');
  const flagMultiline = document.getElementById('flag-multiline');
  const flagDotall = document.getElementById('flag-dotall');
  const flagUnicode = document.getElementById('flag-unicode');
  const clearBtn = document.getElementById('clear-btn');
  const matchSummary = document.getElementById('match-summary');
  const matchCount = document.getElementById('match-count');
  const errorMessage = document.getElementById('error-message');
  const highlightOutput = document.getElementById('highlight-output');
  const matchDetails = document.getElementById('match-details');

  // ---------- 核心邏輯 ----------
  function getFlags() {
    let flags = '';
    if (flagGlobal.checked) flags += 'g';
    if (flagIgnoreCase.checked) flags += 'i';
    if (flagMultiline.checked) flags += 'm';
    if (flagDotall.checked) flags += 's';
    if (flagUnicode.checked) flags += 'u';
    return flags;
  }

  function escapeHtml(text) {
    return String(text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function highlightText(text, matches) {
    if (matches.length === 0) return escapeHtml(text);
    
    // 建立所有匹配的區間（開始、結束），避免重疊（正則匹配通常不重疊）
    const intervals = matches.map(m => ({ start: m.index, end: m.index + m[0].length }));
    intervals.sort((a, b) => a.start - b.start);
    
    let result = '';
    let lastIndex = 0;
    intervals.forEach(interval => {
      // 加入前面的普通文字
      result += escapeHtml(text.slice(lastIndex, interval.start));
      // 加入高亮匹配文字
      result += `<mark class="bg-emerald-500/30 text-emerald-200 rounded px-0.5">${escapeHtml(text.slice(interval.start, interval.end))}</mark>`;
      lastIndex = interval.end;
    });
    // 加入剩餘文字
    result += escapeHtml(text.slice(lastIndex));
    return result;
  }

  function renderResults() {
    const pattern = regexInput.value;
    const testString = testInput.value;
    const flags = getFlags();

    // 隱藏錯誤訊息
    errorMessage.classList.add('hidden');
    matchSummary.classList.add('hidden');
    highlightOutput.innerHTML = escapeHtml(testString) || '<span class="text-zinc-600">No test string</span>';
    matchDetails.innerHTML = '';

    if (!pattern) {
      // 沒有正則表達式就只顯示純文字
      return;
    }

    try {
      const regex = new RegExp(pattern, flags);
      const matches = [...testString.matchAll(regex)];
      
      // 如果沒有 matchAll（不支援全域），退而求其次用單次匹配
      const allMatches = flagGlobal.checked ? matches : (testString.match(regex) ? [testString.match(regex)] : []);
      
      // 顯示匹配數量
      if (allMatches.length > 0) {
        matchSummary.classList.remove('hidden');
        matchCount.textContent = `${allMatches.length} match${allMatches.length > 1 ? 'es' : ''} found`;
      } else {
        matchSummary.classList.add('hidden');
      }

      // 高亮顯示
      highlightOutput.innerHTML = highlightText(testString, allMatches);

      // 顯示詳細分組（只針對非 global 或所有匹配）
      if (allMatches.length > 0) {
        let detailsHtml = '';
        allMatches.forEach((match, index) => {
          detailsHtml += `
            <div class="rounded border border-zinc-800 bg-zinc-900/25 p-4">
              <div class="text-xs font-bold text-zinc-400 mb-2">Match ${index + 1}</div>
              <div class="text-sm font-mono text-emerald-300 break-all">${escapeHtml(match[0])}</div>
              ${match.length > 1 ? `
                <div class="mt-2 space-y-1">
                  <div class="text-xs text-zinc-500">Capture Groups:</div>
                  ${Array.from({ length: match.length - 1 }, (_, i) => i + 1).map(group => `
                    <div class="flex gap-2 text-xs">
                      <span class="text-zinc-600 w-8">\$${group}</span>
                      <span class="font-mono text-zinc-300 break-all">${match[group] !== undefined ? escapeHtml(match[group]) : '<span class="text-zinc-600">undefined</span>'}</span>
                    </div>
                  `).join('')}
                </div>
              ` : ''}
              <div class="mt-1 text-xs text-zinc-600">Index: ${match.index}</div>
            </div>
          `;
        });
        matchDetails.innerHTML = detailsHtml;
      }
    } catch (e) {
      errorMessage.classList.remove('hidden');
      errorMessage.textContent = `Invalid regular expression: ${e.message}`;
      highlightOutput.innerHTML = escapeHtml(testString) || '<span class="text-zinc-600">No test string</span>';
      matchDetails.innerHTML = '';
    }
  }

  // ---------- 事件監聽 ----------
  function debounce(fn, delay = 150) {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  }

  const debouncedRender = debounce(renderResults, 200);

  regexInput.addEventListener('input', debouncedRender);
  testInput.addEventListener('input', debouncedRender);
  flagGlobal.addEventListener('change', renderResults);
  flagIgnoreCase.addEventListener('change', renderResults);
  flagMultiline.addEventListener('change', renderResults);
  flagDotall.addEventListener('change', renderResults);
  flagUnicode.addEventListener('change', renderResults);

  clearBtn.addEventListener('click', () => {
    testInput.value = '';
    renderResults();
    testInput.focus();
  });

  // 初始渲染
  renderResults();
</script>

<style is:global>
  /* 確保 highlight mark 樣式能正常顯示 */
  mark {
    background-color: rgba(16, 185, 129, 0.3);
    color: #a7f3d0;
    border-radius: 0.25rem;
    padding: 0 0.125rem;
  }
</style>