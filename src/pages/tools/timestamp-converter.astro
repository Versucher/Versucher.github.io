---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Timestamp Converter // Tools">
  <header class="border-b border-zinc-800 pb-4">
    <a href="/tools" class="text-xs text-emerald-400 transition hover:text-emerald-300">&lt; Back to tools</a>
    <h2 class="mt-2 text-2xl font-bold text-zinc-100">Timestamp Converter</h2>
    <p class="mt-3 max-w-2xl text-sm leading-6 text-zinc-400">
      Convert between Unix timestamps and human-readable dates — instantly.
    </p>
  </header>

  <div id="timestamp-app" class="mt-6 space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-4">
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Unix Timestamp (seconds)</label>
          <input type="number" id="timestamp-input" placeholder="e.g. 1717200000" class="w-full rounded border border-zinc-800 bg-zinc-900/50 px-3 py-2 text-sm font-mono text-zinc-200 outline-none focus:border-emerald-500">
          <button id="now-btn" class="mt-2 text-xs text-zinc-400 hover:text-emerald-400">Use current time</button>
        </div>
        <div>
          <label class="block text-xs text-zinc-400 mb-1">Date & Time (local)</label>
          <input type="datetime-local" id="date-input" class="w-full rounded border border-zinc-800 bg-zinc-900/50 px-3 py-2 text-sm text-zinc-200 outline-none focus:border-emerald-500">
        </div>
      </div>
      <div class="rounded border border-zinc-800 bg-zinc-950 p-4 space-y-3 text-sm">
        <div><span class="text-zinc-500">ISO 8601:</span> <span id="iso-display" class="font-mono text-zinc-300">—</span></div>
        <div><span class="text-zinc-500">UTC:</span> <span id="utc-display" class="font-mono text-zinc-300">—</span></div>
        <div><span class="text-zinc-500">Local:</span> <span id="local-display" class="font-mono text-zinc-300">—</span></div>
        <div><span class="text-zinc-500">Relative:</span> <span id="relative-display" class="font-mono text-emerald-400">—</span></div>
        <div class="pt-2 border-t border-zinc-800">
          <span class="text-zinc-500">Unix Timestamp (ms):</span> <span id="ms-display" class="font-mono text-zinc-300">—</span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const timestampInput = document.getElementById('timestamp-input');
  const dateInput = document.getElementById('date-input');
  const nowBtn = document.getElementById('now-btn');
  const isoDisplay = document.getElementById('iso-display');
  const utcDisplay = document.getElementById('utc-display');
  const localDisplay = document.getElementById('local-display');
  const relativeDisplay = document.getElementById('relative-display');
  const msDisplay = document.getElementById('ms-display');

  function updateFromTimestamp(ts) {
    const num = parseInt(ts);
    if (isNaN(num)) {
      isoDisplay.textContent = utcDisplay.textContent = localDisplay.textContent = relativeDisplay.textContent = msDisplay.textContent = '—';
      return;
    }
    // 支援秒或毫秒 (若 > 1e12 則為毫秒)
    const date = num > 1e12 ? new Date(num) : new Date(num * 1000);
    const iso = date.toISOString();
    isoDisplay.textContent = iso;
    utcDisplay.textContent = date.toUTCString();
    localDisplay.textContent = date.toString();
    msDisplay.textContent = num > 1e12 ? num : num * 1000;
    // 相對時間
    relativeDisplay.textContent = getRelativeTime(date);
    // 更新日期輸入框 (本地時間)
    const yyyy = date.getFullYear();
    const mm = String(date.getMonth() + 1).padStart(2, '0');
    const dd = String(date.getDate()).padStart(2, '0');
    const hh = String(date.getHours()).padStart(2, '0');
    const mi = String(date.getMinutes()).padStart(2, '0');
    dateInput.value = `${yyyy}-${mm}-${dd}T${hh}:${mi}`;
  }

  function updateFromDate(dateStr) {
    if (!dateStr) return;
    const date = new Date(dateStr);
    if (isNaN(date.getTime())) return;
    const tsSeconds = Math.floor(date.getTime() / 1000);
    timestampInput.value = tsSeconds;
    updateFromTimestamp(tsSeconds);
  }

  function getRelativeTime(date) {
    const now = new Date();
    const diff = now - date;
    const seconds = Math.floor(diff / 1000);
    if (seconds < 0) return 'in the future';
    const intervals = [
      { label: 'year', seconds: 31536000 },
      { label: 'month', seconds: 2592000 },
      { label: 'day', seconds: 86400 },
      { label: 'hour', seconds: 3600 },
      { label: 'minute', seconds: 60 },
    ];
    for (const interval of intervals) {
      const count = Math.floor(seconds / interval.seconds);
      if (count >= 1) return count + ' ' + interval.label + (count > 1 ? 's' : '') + ' ago';
    }
    return 'just now';
  }

  timestampInput.addEventListener('input', (e) => updateFromTimestamp(e.target.value));
  dateInput.addEventListener('input', (e) => updateFromDate(e.target.value));
  nowBtn.addEventListener('click', () => {
    timestampInput.value = Math.floor(Date.now() / 1000);
    updateFromTimestamp(timestampInput.value);
  });

  // 初始載入目前時間
  nowBtn.click();
</script>